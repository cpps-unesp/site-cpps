---
import NoticiaCard from './NoticiaCard.astro';
import type { CollectionEntry } from 'astro:content';
import { getTranslatedPath } from '../utils/getTranslatedPath';
import type { SupportedLang } from '../types/lang';

interface Props {
  noticias: CollectionEntry<'noticias'>[];
  lang: SupportedLang;
}

const { noticias, lang } = Astro.props;
---

<div class="grid gap-8 md:grid-cols-2">
  {
    noticias.map((post) => (
      <NoticiaCard
        title={post.data.title}
        resumo={post.data.resumo}
        image={post.data.image}
        tags={post.data.tags}
        slug={`/${lang}/${getTranslatedPath('noticias', lang)}/${post.slug}`}
        lang={lang}
        date={post.data.date}
        author={post.data.author}
      />
    ))
  }
</div>
