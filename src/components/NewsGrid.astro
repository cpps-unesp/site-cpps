---
import NoticiaCard from './NoticiaCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  noticias: CollectionEntry<'noticias'>[];
  lang: string;
}

const { noticias, lang } = Astro.props;
const getNewsSlug = (post: (typeof noticias)[number]) =>
  post.slug || post.data.slug || post.id.replace(/\.[^/.]+$/, '');
---

<div class="grid gap-8 md:grid-cols-2">
  {
    noticias.map((post) => (
      <NoticiaCard
        title={post.data.title}
        resumo={post.data.resumo}
        image={post.data.image}
        tags={post.data.tags}
        slug={`/${lang}/noticias/${getNewsSlug(post)}`}
        lang={lang}
        date={post.data.date}
        author={post.data.author}
      />
    ))
  }
</div>
