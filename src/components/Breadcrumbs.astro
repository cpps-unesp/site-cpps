---
const { lang = 'pt', slugArray = [], texts = {} } = Astro.props;
const basePath = import.meta.env.BASE_URL;
const withBase = (path: string) => `${basePath}${path.replace(/^\//, '')}`;
---

<nav class="breadcrumbs mb-4 text-sm">
  <ul>
    <li><a href={withBase(`/${lang}/`)}>{texts.breadcrumbHome}</a></li>

    {
      slugArray.map((part: string, index: number) => {
        const href = withBase(`/${lang}/${slugArray.slice(0, index + 1).join('/')}`);
        const label = part.charAt(0).toUpperCase() + part.slice(1);
        return (
          <li>
            <a href={href}>{label}</a>
          </li>
        );
      })
    }
  </ul>
</nav>
