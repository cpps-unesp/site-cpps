---
import NoticiaCard from './NoticiaCard.astro';
import type { SupportedLang } from '../types/lang';
import { getTranslatedPath } from '../utils/getTranslatedPath';

const { noticias, lang } = Astro.props as { noticias: Array<any>; lang: SupportedLang };
const newsPrefix = getTranslatedPath('noticias', lang);
---

<section class="mx-auto max-w-screen-xl px-4 py-12 md:px-8">
  <h2 class="titulo text-primary mb-12 text-center">Notícias</h2>

  <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
    {
      noticias.map((post) => (
        <NoticiaCard
          title={post.data.title}
          resumo={post.data.resumo}
          image={post.data.image}
          tags={post.data.tags}
          slug={`/${lang}/${newsPrefix}/${post.slug}`}
          lang={lang}
        />
      ))
    }
  </div>
</section>
