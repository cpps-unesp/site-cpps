---
// IconSocial.astro
const { tipo, url, tamanho = 'text-lg' } = Astro.props;

// Normaliza o nome para facilitar comparações
const tipoNormalizado = tipo.toLowerCase();

const iconSizeClass = tamanho === 'text-xl' ? 'w-6 h-6' : 'w-5 h-5';
const basePath = import.meta.env.BASE_URL;
const withBase = (path: string) => `${basePath}${path.replace(/^\//, '')}`;
---

<a
  href={url}
  target="_blank"
  rel="noopener"
  title={tipo}
  class="inline-flex items-center justify-center transition-transform hover:scale-110"
>
  {
    tipoNormalizado === 'linkedin' ? (
      <i class={`fab fa-linkedin ${tamanho}`} />
    ) : tipoNormalizado === 'lattes' ? (
      <img
        src={withBase('/imagens/logos/lattes_icon.svg')}
        alt="Lattes"
        class={`${iconSizeClass} object-contain`}
        loading="lazy"
      />
    ) : tipoNormalizado === 'orcid' ? (
      <img
        src={withBase('/imagens/logos/orcid.png')}
        alt="ORCID"
        class={`${iconSizeClass} object-contain`}
        loading="lazy"
      />
    ) : tipoNormalizado === 'portal-docente-unesp' ? (
      <img
        src={withBase('/imagens/logos/logo-unesp-mapa.svg')}
        alt="Portal Docente UNESP"
        class="h-8 w-8 object-contain"
        loading="lazy"
      />
    ) : (
      // Ícone padrão (fallback) se tipo não for reconhecido
      <span class={`${tamanho}`}>🔗</span>
    )
  }
</a>
