---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaseTesteAlert from './FaseTesteAlert.astro';
import NewsFeatured from './NewsFeatured.astro';
import NewsGrid from './NewsGrid.astro';
import NewsSidebar from './NewsSidebar.astro';
import { getCollection } from 'astro:content';
import { getTranslations } from '../utils/i18n';
import type { SupportedLang } from '../types/lang';
import slugify from 'slugify';

const { lang, tag = null } = Astro.props as { lang: SupportedLang; tag?: string | null };
const locale = getTranslations(lang);

const allNoticias = await getCollection('noticias');

const langNoticias = allNoticias
  .filter((post) => post.data.lang === lang)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

let displayedNoticias = langNoticias;
let featuredPost = null;
let titlePage = locale.texts.header.noticias || 'Notícias';

if (tag) {
  displayedNoticias = langNoticias.filter((post) =>
    post.data.tags?.some((t) => slugify(t, { lower: true, strict: true }) === tag)
  );
  const actualTagName =
    displayedNoticias[0]?.data.tags.find(
      (t) => slugify(t, { lower: true, strict: true }) === tag
    ) || tag;
  titlePage = `${titlePage}: ${actualTagName}`;
} else {
  // Logic for featured post only on main news page
  featuredPost = langNoticias.find((post) => post.data.featured) || langNoticias[0];
  displayedNoticias = langNoticias.filter((post) => post.id !== featuredPost?.id);
}
---

<BaseLayout
  lang={lang}
  titulo={titlePage}
  descricao={locale.descricao}
  texts={locale.texts}
  identidade={locale.identidade}
>
  <main class="container mx-auto px-4 py-12">
    <FaseTesteAlert lang={lang} area={locale.texts.header.noticias || 'Notícias'} />
    <header class="mb-12">
      <h1 class="text-primary mb-4 text-5xl font-bold">{titlePage}</h1>
      <div class="bg-primary h-1.5 w-20"></div>
    </header>

    {featuredPost && <NewsFeatured post={featuredPost} lang={lang} />}

    <div class="grid gap-12 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <NewsGrid noticias={displayedNoticias} lang={lang} />
        {
          displayedNoticias.length === 0 && (
            <p class="py-10 text-center opacity-50">
              {locale.noticias?.noResults || 'Nenhuma notícia encontrada nesta categoria.'}
            </p>
          )
        }
        <nav id="news-pagination" class="mt-10 flex items-center justify-center gap-2" aria-label="Paginação de notícias"></nav>
      </div>

      <div>
        <NewsSidebar noticias={langNoticias} lang={lang} texts={locale.texts} />
      </div>
    </div>
  </main>

<script>
  const ITEMS_PER_PAGE = 10;

  function setupNewsPagination() {
    const grid = document.getElementById('news-grid');
    const paginationEl = document.getElementById('news-pagination');
    if (!grid || !paginationEl) return;

    const cards = Array.from(grid.querySelectorAll('article'));
    const totalPages = Math.ceil(cards.length / ITEMS_PER_PAGE);

    if (totalPages <= 1) {
      paginationEl.style.display = 'none';
      return;
    }

    let currentPage = 1;

    function showPage(page: number) {
      currentPage = page;
      const start = (page - 1) * ITEMS_PER_PAGE;
      const end = start + ITEMS_PER_PAGE;
      cards.forEach((card, i) => {
        (card as HTMLElement).style.display = i >= start && i < end ? '' : 'none';
      });
      renderPagination();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function renderPagination() {
      paginationEl!.innerHTML = '';

      const prev = document.createElement('button');
      prev.textContent = '←';
      prev.disabled = currentPage === 1;
      prev.className = 'btn btn-sm btn-outline';
      prev.addEventListener('click', () => showPage(currentPage - 1));
      paginationEl!.appendChild(prev);

      for (let i = 1; i <= totalPages; i++) {
        const btn = document.createElement('button');
        btn.textContent = String(i);
        btn.className = `btn btn-sm ${i === currentPage ? 'btn-primary' : 'btn-outline'}`;
        btn.addEventListener('click', () => showPage(i));
        paginationEl!.appendChild(btn);
      }

      const next = document.createElement('button');
      next.textContent = '→';
      next.disabled = currentPage === totalPages;
      next.className = 'btn btn-sm btn-outline';
      next.addEventListener('click', () => showPage(currentPage + 1));
      paginationEl!.appendChild(next);
    }

    showPage(1);
  }

  setupNewsPagination();
  document.addEventListener('astro:after-swap', setupNewsPagination);
</script>

</BaseLayout>
