---
import { getCollection } from 'astro:content';
import type { SupportedLang } from '../../../types/lang';
import { resolveAtividadesLegacyPath } from '../../../utils/atividadesLegacyRedirect';
import { filterVisibleDocsEntries } from '../../../utils/docsVisibility';
import routeTranslations from '../../../i18n/routeTranslations';
import {
  getLegacyAtividadesAliasSources,
  normalizeLegacyAtividadesSlug,
} from '../../../utils/wikiLegacyAliases';
import { withBasePath } from '../../../utils/basePath';

export async function getStaticPaths() {
  const langs: SupportedLang[] = ['pt', 'en', 'es'];
  const entries = filterVisibleDocsEntries(await getCollection('atividades'));
  const singleSegmentSources = new Set<string>();

  for (const entry of entries) {
    if (!entry.slug.includes('/')) {
      singleSegmentSources.add(entry.slug);
    }
  }

  for (const source of getLegacyAtividadesAliasSources()) {
    if (!source.includes('/')) {
      singleSegmentSources.add(source);
    }
  }

  const paths: Array<{ params: { lang: SupportedLang; slug: string } }> = [];

  for (const lang of langs) {
    for (const slug of singleSegmentSources) {
      paths.push({ params: { lang, slug } });
    }
  }

  return paths;
}

const lang = (Astro.params.lang ?? 'pt') as SupportedLang;
const slug = Astro.params.slug ?? '';
const entries = filterVisibleDocsEntries(await getCollection('atividades'));
const validSlugs = new Set(entries.map((entry) => entry.slug));
const redirectPath = resolveAtividadesLegacyPath(
  lang,
  normalizeLegacyAtividadesSlug(slug),
  validSlugs
);

if (redirectPath) {
  return Astro.redirect(redirectPath, 301);
}

return Astro.redirect(
  withBasePath(`/${lang}/${routeTranslations.atividades[lang]}`, import.meta.env.BASE_URL),
  302
);
---
