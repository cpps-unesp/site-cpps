---
export const prerender = true;

import type { SupportedLang } from '../../types/lang';
import { withBasePath } from '../../utils/basePath';

export function getStaticPaths() {
  return [{ params: { lang: 'pt' } }, { params: { lang: 'en' } }, { params: { lang: 'es' } }];
}

const lang = (Astro.params.lang ?? 'pt') as SupportedLang;

if (lang !== 'es') {
  return Astro.redirect(withBasePath(`/${lang}/`, import.meta.env.BASE_URL), 302);
}

return Astro.redirect(withBasePath(`/${lang}/atividades`, import.meta.env.BASE_URL), 301);
---